@model TicketBookingSystem.Mvc.ViewModels.PaymentViewModel

@{
    ViewData["Title"] = "Complete Payment";
    var amt = Model.Amount.ToString(System.Globalization.CultureInfo.InvariantCulture);
    bool showQR = !string.IsNullOrEmpty(Model.QRCodeBase64);
    bool showRazorpay = !string.IsNullOrEmpty(Model.RazorpayOrderId);
}

<style>
    .pay-page {
        background-color: #F8F7FF;
        min-height: 80vh;
        padding: 2.5rem 0;
    }

    .pay-hero {
        background: linear-gradient(135deg, #2e8b57, #20b2aa);
        border-radius: 16px 16px 0 0;
        padding: 1.75rem 2rem;
        color: #fff;
    }

        .pay-hero .label {
            font-size: .8rem;
            opacity: .8;
            text-transform: uppercase;
            letter-spacing: .06em;
            margin-bottom: 4px;
        }

        .pay-hero .amount {
            font-size: 2.2rem;
            font-weight: 700;
            letter-spacing: -.5px;
        }

        .pay-hero .booking-ref {
            font-size: .85rem;
            opacity: .75;
            margin-top: 2px;
        }

    .pay-card {
        max-width: 500px;
        margin: 0 auto;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(46,139,87,.13);
        background: #fff;
    }

    .pay-tabs {
        border-bottom: 1px solid #e8f5f0;
        padding: 0 1.5rem;
        background: #fff;
    }

        .pay-tabs .nav-link {
            color: #6c757d;
            font-size: .9rem;
            font-weight: 500;
            padding: .85rem 1rem;
            border: none;
            border-bottom: 2px solid transparent;
            border-radius: 0;
            background: transparent;
        }

            .pay-tabs .nav-link.active {
                color: #2e8b57;
                border-bottom-color: #2e8b57;
                background: transparent;
            }

            .pay-tabs .nav-link:hover:not(.active) {
                color: #20b2aa;
            }

    .pay-body {
        padding: 1.75rem;
        background: #fff;
    }

    .card-preview-box {
        background: linear-gradient(135deg, #1a3a2a, #0d2b2b);
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.25rem;
        color: #fff;
        position: relative;
        overflow: hidden;
    }

        .card-preview-box::after {
            content: '';
            position: absolute;
            top: -20px;
            right: -20px;
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background: rgba(32,178,170,.15);
        }

    .card-chip {
        width: 30px;
        height: 22px;
        background: linear-gradient(135deg, #F0C955, #d4a017);
        border-radius: 4px;
        margin-bottom: 12px;
    }

    .card-num-display {
        font-size: 1.05rem;
        letter-spacing: .2em;
        margin-bottom: 10px;
    }

    .card-holder-display {
        font-size: .75rem;
        opacity: .5;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .form-label {
        font-size: .8rem;
        font-weight: 600;
        color: #444;
        text-transform: uppercase;
        letter-spacing: .04em;
        margin-bottom: 5px;
    }

    .form-control {
        border: 1px solid #d8ede6;
        border-radius: 8px;
        padding: .55rem .85rem;
        font-size: .9rem;
        background: #f8fdfb;
    }

        .form-control:focus {
            border-color: #2e8b57;
            box-shadow: 0 0 0 3px rgba(46,139,87,.1);
            background: #fff;
        }

    .btn-pay {
        background: linear-gradient(90deg, #2e8b57, #20b2aa);
        color: #fff !important;
        border: none;
        border-radius: 8px;
        padding: .7rem 1rem;
        font-size: .95rem;
        font-weight: 600;
        width: 100%;
        transition: all .2s;
        margin-top: 4px;
        cursor: pointer;
        display: block;
        text-align: center;
    }

        .btn-pay:hover {
            background: linear-gradient(90deg, #20b2aa, #2e8b57);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(46,139,87,.25);
        }

    .btn-pay-outline {
        background: #fff;
        color: #2e8b57 !important;
        border: 1.5px solid #2e8b57;
        border-radius: 8px;
        padding: .65rem 1rem;
        font-size: .9rem;
        font-weight: 600;
        width: 100%;
        transition: all .2s;
        margin-top: 8px;
        cursor: pointer;
        display: block;
        text-align: center;
        text-decoration: none;
    }

        .btn-pay-outline:hover {
            background: #f0faf5;
        }

    .upi-apps {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 8px;
        margin-bottom: 1.25rem;
    }

    .upi-app {
        border: 1.5px solid #d8ede6;
        border-radius: 10px;
        padding: 10px 4px;
        text-align: center;
        cursor: pointer;
        font-size: .72rem;
        font-weight: 500;
        color: #444;
        background: #f8fdfb;
        transition: all .15s;
    }

        .upi-app.active, .upi-app:hover {
            border-color: #2e8b57;
            background: #e8f5f0;
            color: #2e8b57;
        }

        .upi-app .icon {
            font-size: 1.3rem;
            display: block;
            margin-bottom: 4px;
        }

    .qr-steps {
        display: flex;
        gap: 8px;
        margin-bottom: 1rem;
    }

    .qr-step {
        flex: 1;
        background: #f0faf5;
        border-radius: 8px;
        padding: 8px 4px;
        text-align: center;
        font-size: .72rem;
        color: #2e8b57;
        font-weight: 500;
    }

        .qr-step strong {
            display: block;
            font-size: 1.1rem;
            color: #1a5c38;
            margin-bottom: 2px;
        }

    .qr-box {
        text-align: center;
        padding: 1.25rem;
        border: 1.5px solid #d8ede6;
        border-radius: 12px;
        background: #f8fdfb;
        margin-bottom: 1rem;
    }

        .qr-box img {
            width: 185px;
            height: 185px;
            border-radius: 8px;
        }

    .bank-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        margin-bottom: 1rem;
    }

    .bank-item {
        border: 1.5px solid #d8ede6;
        border-radius: 10px;
        padding: 10px 12px;
        cursor: pointer;
        font-size: .85rem;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 8px;
        background: #f8fdfb;
        transition: all .15s;
        color: #333;
    }

        .bank-item:hover, .bank-item.selected {
            border-color: #2e8b57;
            background: #e8f5f0;
            color: #2e8b57;
        }

    .bank-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .divider {
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 1rem 0;
        font-size: .8rem;
        color: #aaa;
    }

        .divider::before, .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #e0ede8;
        }

    .secure-footer {
        text-align: center;
        padding: 1rem 1.75rem;
        font-size: .75rem;
        color: #aaa;
        border-top: 1px solid #f0f0f0;
    }

        .secure-footer span {
            color: #2e8b57;
            font-weight: 600;
        }

    .order-summary {
        background: #f0faf5;
        border: 1px solid #d8ede6;
        border-radius: 10px;
        padding: 1rem 1.25rem;
        margin-bottom: 1.25rem;
        font-size: .875rem;
    }

        .order-summary .row-item {
            display: flex;
            justify-content: space-between;
            padding: 4px 0;
            color: #555;
        }

            .order-summary .row-item.total {
                border-top: 1px solid #c8e6d8;
                margin-top: 6px;
                padding-top: 8px;
                font-weight: 700;
                color: #1a5c38;
                font-size: .95rem;
            }
</style>

<div class="pay-page">
    <div class="container">
        <div class="pay-card">

            @* HERO HEADER *@
            <div class="pay-hero">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="label">&#128274; Secure Payment</div>
                        <div class="amount">&#8377;@Model.Amount.ToString("N0")</div>
                        <div class="booking-ref">Cruise Booking &middot; Ref #@Model.BookingId</div>
                    </div>
                    <div style="text-align:right;opacity:.85;font-size:.8rem;margin-top:4px">
                        <div>Powered by</div>
                        <div style="font-weight:700;font-size:1rem">Razorpay</div>
                    </div>
                </div>
            </div>

            @* ERROR *@
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger m-3 mb-0 rounded-3 small">
                    &#9888; @Model.ErrorMessage
                </div>
            }

            @* RAZORPAY MODAL VIEW *@
            @if (showRazorpay)
            {
                <div class="pay-body">
                    <div class="order-summary">
                        <div class="row-item"><span>Payment Method</span><span>@Model.PaymentMethod</span></div>
                        <div class="row-item"><span>Booking Ref</span><span>#@Model.BookingId</span></div>
                        <div class="row-item total"><span>Total</span><span>&#8377;@Model.Amount.ToString("N0")</span></div>
                    </div>
                    <div class="alert small mb-3" style="background:#e8f5f0;color:#1a5c38;border:1px solid #c8e6d8;border-radius:8px">
                        &#10003; Order created. Complete your payment below.
                    </div>
                    <button class="btn-pay" onclick="openRazorpay()">
                        Complete Payment &#8377;@Model.Amount.ToString("N0")
                    </button>
                    <a href="/Payment?bookingId=@Model.BookingId&amount=@amt" class="btn-pay-outline">
                        &#8592; Go Back
                    </a>
                </div>

                <form id="verify-form" method="post" asp-action="Verify" asp-controller="Payment">
                    <input type="hidden" name="BookingId" value="@Model.BookingId" />
                    <input type="hidden" name="Amount" value="@amt" />
                    <input type="hidden" name="PaymentMethod" value="@Model.PaymentMethod" />
                    <input type="hidden" name="RazorpayOrderId" id="f-order-id" value="" />
                    <input type="hidden" name="RazorpayPaymentId" id="f-payment-id" value="" />
                    <input type="hidden" name="RazorpaySignature" id="f-signature" value="" />
                </form>

                <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
                <script>
                    window.onload = function () { openRazorpay(); };
                    function openRazorpay() {
                        var options = {
                            key: "@Model.RazorpayKeyId",
                            amount: @Model.RazorpayAmount,
                            currency: "INR",
                            name: "Cruise Booking",
                            description: "Booking #@Model.BookingId",
                            order_id: "@Model.RazorpayOrderId",
                            handler: function (response) {
                                document.getElementById('f-order-id').value = response.razorpay_order_id;
                                document.getElementById('f-payment-id').value = response.razorpay_payment_id;
                                document.getElementById('f-signature').value = response.razorpay_signature;
                                document.getElementById('verify-form').submit();
                            },
                            theme: { color: "#2e8b57" },
                            modal: {
                                ondismiss: function () {
                                    window.location.href = "/Payment?bookingId=@Model.BookingId&amount=@amt";
                                }
                            }
                        };
                        var rzp = new Razorpay(options);
                        rzp.open();
                    }
                </script>
            }
            else
            {
                @* TABS *@
                <div class="pay-tabs">
                    <ul class="nav" id="payTab">
                        <li class="nav-item">
                            <button class="nav-link @(Model.PaymentMethod == "UPI" ? "" : "active")"
                                    data-bs-toggle="tab" data-bs-target="#tab-card">
                                &#128179; Card
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link @(Model.PaymentMethod == "UPI" ? "active" : "")"
                                    data-bs-toggle="tab" data-bs-target="#tab-upi">
                                &#128241; UPI
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-nb">
                                &#127974; Net Banking
                            </button>
                        </li>
                    </ul>
                </div>

                <div class="tab-content">

                    @* CARD TAB *@
                    <div class="tab-pane fade @(Model.PaymentMethod == "UPI" ? "" : "show active")" id="tab-card">
                        <div class="pay-body">
                            <div class="card-preview-box">
                                <div class="card-chip"></div>
                                <div class="card-num-display" id="cp-num">
                                    &#8226;&#8226;&#8226;&#8226; &#8226;&#8226;&#8226;&#8226; &#8226;&#8226;&#8226;&#8226; &#8226;&#8226;&#8226;&#8226;
                                </div>
                                <div class="card-holder-display" id="cp-name">Cardholder name</div>
                            </div>
                            <form method="post" asp-action="InitiateCard" asp-controller="Payment">
                                <input type="hidden" name="BookingId" value="@Model.BookingId" />
                                <input type="hidden" name="Amount" value="@amt" />
                                <div class="mb-3">
                                    <label class="form-label">Card number</label>
                                    <input type="text" class="form-control" name="CardNumber" id="cardnum"
                                           maxlength="16" placeholder="1234567890123456" required />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Name on card</label>
                                    <input type="text" class="form-control" name="CardHolderName" id="cname"
                                           placeholder="As it appears on card" required />
                                </div>
                                <div class="row g-2 mb-3">
                                    <div class="col">
                                        <label class="form-label">Expiry</label>
                                        <input type="text" class="form-control" name="Expiry"
                                               maxlength="5" placeholder="MM/YY" required />
                                    </div>
                                    <div class="col">
                                        <label class="form-label">CVV</label>
                                        <input type="text" class="form-control" name="CVV"
                                               maxlength="3" placeholder="123" required />
                                    </div>
                                </div>
                                <button type="submit" class="btn-pay">
                                    Pay &#8377;@Model.Amount.ToString("N0")
                                </button>
                            </form>
                        </div>
                    </div>

                    @* UPI TAB *@
                    <div class="tab-pane fade @(Model.PaymentMethod == "UPI" ? "show active" : "")" id="tab-upi">
                        <div class="pay-body">
                            @if (showQR)
                            {
                                <div class="qr-steps">
                                    <div class="qr-step"><strong>1</strong>Open app</div>
                                    <div class="qr-step"><strong>2</strong>Scan QR</div>
                                    <div class="qr-step"><strong>3</strong>Confirm</div>
                                </div>
                                <div class="qr-box">
                                    <img src="data:image/png;base64,@Model.QRCodeBase64"
                                         alt="UPI QR Code" class="mb-2" />
                                    <div class="fw-semibold small mt-2" style="color:#1a5c38">
                                        Scan to pay &#8377;@Model.Amount.ToString("N0")
                                    </div>
                                    <div class="text-muted" style="font-size:.75rem">smartcruise&#64;upi</div>
                                </div>
                                <form method="post" asp-action="ConfirmUpi" asp-controller="Payment">
                                    <input type="hidden" name="BookingId" value="@Model.BookingId" />
                                    <input type="hidden" name="Amount" value="@amt" />
                                    <button type="submit" class="btn-pay">
                                        &#10003; I have paid &mdash; Confirm Payment
                                    </button>
                                </form>
                                <a href="/Payment?bookingId=@Model.BookingId&amount=@amt"
                                   class="btn-pay-outline">
                                    &#8592; Try another method
                                </a>
                            }
                            else
                            {
                                <div class="upi-apps">
                                    <div class="upi-app active" onclick="pickUpi(this)">
                                        <span class="icon">&#127254;</span>GPay
                                    </div>
                                    <div class="upi-app" onclick="pickUpi(this)">
                                        <span class="icon">&#128242;</span>PhonePe
                                    </div>
                                    <div class="upi-app" onclick="pickUpi(this)">
                                        <span class="icon">&#128153;</span>Paytm
                                    </div>
                                    <div class="upi-app" onclick="pickUpi(this)">
                                        <span class="icon">&#127470;&#127475;</span>BHIM
                                    </div>
                                </div>
                                <form method="post" asp-action="GenerateQR" asp-controller="Payment">
                                    <input type="hidden" name="BookingId" value="@Model.BookingId" />
                                    <input type="hidden" name="Amount" value="@amt" />
                                    <button type="submit" class="btn-pay">
                                        &#128247; Generate QR Code
                                    </button>
                                </form>

                                <div class="divider">or pay with UPI ID</div>

                                <form method="post" asp-action="UpiIdPay" asp-controller="Payment">
                                    <input type="hidden" name="BookingId" value="@Model.BookingId" />
                                    <input type="hidden" name="Amount" value="@amt" />
                                    <label class="form-label">UPI ID</label>
                                    <div class="input-group">
                                        <input type="text" class="form-control" name="UpiId"
                                               placeholder="yourname&#64;upi" required />
                                        <button type="submit"
                                                style="background:linear-gradient(90deg,#2e8b57,#20b2aa);color:#fff;border:none;padding:.55rem 1.1rem;border-radius:0 8px 8px 0;font-weight:600;cursor:pointer">
                                            Pay
                                        </button>
                                    </div>
                                </form>
                            }
                        </div>
                    </div>

                    @* NET BANKING TAB *@
                    <div class="tab-pane fade" id="tab-nb">
                        <div class="pay-body">
                            <form method="post" asp-action="InitiateNB" asp-controller="Payment">
                                <input type="hidden" name="BookingId" value="@Model.BookingId" />
                                <input type="hidden" name="Amount" value="@amt" />
                                <input type="hidden" name="SelectedBank" id="selected-bank-input" value="" />
                                <p class="small text-muted mb-3">Select your bank to continue</p>
                                <div class="bank-grid">
                                    <div class="bank-item" onclick="pickBank(this,'HDFC')">
                                        <div class="bank-dot" style="background:#003087"></div>HDFC Bank
                                    </div>
                                    <div class="bank-item" onclick="pickBank(this,'ICICI')">
                                        <div class="bank-dot" style="background:#e31837"></div>ICICI Bank
                                    </div>
                                    <div class="bank-item" onclick="pickBank(this,'SBI')">
                                        <div class="bank-dot" style="background:#22409A"></div>SBI
                                    </div>
                                    <div class="bank-item" onclick="pickBank(this,'AXIS')">
                                        <div class="bank-dot" style="background:#004B87"></div>Axis Bank
                                    </div>
                                    <div class="bank-item" onclick="pickBank(this,'KOTAK')">
                                        <div class="bank-dot" style="background:#E91E8C"></div>Kotak
                                    </div>
                                    <div class="bank-item" onclick="pickBank(this,'PNB')">
                                        <div class="bank-dot" style="background:#FF6B00"></div>PNB
                                    </div>
                                </div>
                                <div id="bank-error" class="small mb-2" style="color:#dc3545;display:none">
                                    &#9888; Please select a bank first
                                </div>
                                <button type="submit" class="btn-pay" onclick="return validateBank()">
                                    Pay via Net Banking &#8377;@Model.Amount.ToString("N0")
                                </button>
                            </form>
                        </div>
                    </div>

                </div>
            }

            <div class="secure-footer">
                &#128274; 256-bit SSL &middot; PCI DSS Compliant &middot; Powered by <span>Razorpay</span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var cardnumEl = document.getElementById('cardnum');
        var cnameEl = document.getElementById('cname');
        if (cardnumEl) {
            cardnumEl.addEventListener('input', function () {
                var v = this.value.replace(/[^0-9]/g, '').slice(0, 16);
                var p = v.padEnd(16, '\u2022');
                document.getElementById('cp-num').textContent = p.replace(/(.{4})/g, '$1 ').trim();
            });
        }
        if (cnameEl) {
            cnameEl.addEventListener('input', function () {
                document.getElementById('cp-name').textContent = this.value || 'Cardholder name';
            });
        }
        function pickUpi(el) {
            document.querySelectorAll('.upi-app').forEach(function (a) { a.classList.remove('active'); });
            el.classList.add('active');
        }
        function pickBank(el, bank) {
            document.querySelectorAll('.bank-item').forEach(function (b) { b.classList.remove('selected'); });
            el.classList.add('selected');
            document.getElementById('selected-bank-input').value = bank;
            document.getElementById('bank-error').style.display = 'none';
        }
        function validateBank() {
            if (!document.getElementById('selected-bank-input').value) {
                document.getElementById('bank-error').style.display = 'block';
                return false;
            }
            return true;
        }
    </script>
}
