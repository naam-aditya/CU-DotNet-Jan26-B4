@model List<TicketBookingSystem.Mvc.ViewModels.ItineraryItemViewModel>

@{
    ViewData["Title"] = "Manage Itinerary";
    var trips = ViewBag.Trips as IReadOnlyList<TicketBookingSystem.Mvc.ViewModels.TripViewModel> ?? new List<TicketBookingSystem.Mvc.ViewModels.TripViewModel>();
    var selectedTripId = (int)(ViewBag.SelectedTripId ?? 0);
    var selectedTrip = ViewBag.SelectedTrip as TicketBookingSystem.Mvc.ViewModels.TripViewModel;
}

<style>
    :root {
        --brand: #32B096;
        --brand-dark: #279078;
        --ink: #0f172a;
        --muted: #64748b;
        --border: #e2e8f0;
        --surface: #f8fafc;
    }

    .admin-header {
        background: linear-gradient(135deg,#1e293b,#0f172a);
        color: #fff;
        padding: 2rem 0;
        margin-bottom: 2rem;
    }

        .admin-header h2 {
            font-weight: 800;
            font-size: 1.8rem;
        }

    .admin-nav {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(10,37,64,.06);
        padding: 1rem 1.5rem;
        margin-bottom: 2rem;
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
    }

        .admin-nav a {
            padding: .5rem 1.2rem;
            border-radius: 50px;
            font-weight: 600;
            font-size: .88rem;
            text-decoration: none;
            color: var(--muted);
            transition: all .2s;
        }

            .admin-nav a:hover, .admin-nav a.active {
                background: var(--brand);
                color: #fff;
            }

    .admin-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(10,37,64,.08);
        overflow: hidden;
        margin-bottom: 1.5rem;
    }

    .admin-card-header {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .admin-card-header h5 {
            font-weight: 700;
            margin: 0;
        }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
    }

        .admin-table th {
            font-size: .72rem;
            font-weight: 700;
            letter-spacing: .7px;
            text-transform: uppercase;
            color: var(--muted);
            padding: .9rem 1.25rem;
            border-bottom: 1px solid var(--border);
            background: #fafbfc;
        }

        .admin-table td {
            padding: .9rem 1.25rem;
            border-bottom: 1px solid var(--border);
            font-size: .88rem;
            color: var(--ink);
            vertical-align: middle;
        }

        .admin-table tr:last-child td {
            border-bottom: none;
        }

        .admin-table tr:hover td {
            background: #f8fafc;
        }

    .btn-del-sm {
        background: #fff0f0;
        color: #ef4444;
        border: 1.5px solid #ef4444;
        padding: .3rem .8rem;
        border-radius: 8px;
        font-size: .78rem;
        font-weight: 600;
        cursor: pointer;
    }

    .form-label {
        font-size: .78rem;
        font-weight: 600;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: .6px;
    }

    .form-control, .form-select {
        border: 1.5px solid var(--border);
        border-radius: 12px;
        padding: .65rem 1rem;
        font-size: .9rem;
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--brand);
            box-shadow: 0 0 0 3px rgba(50,176,150,.15);
        }

    .btn-add {
        background: linear-gradient(135deg,var(--brand),var(--brand-dark));
        color: #fff;
        border: none;
        padding: .65rem 1.5rem;
        border-radius: 50px;
        font-weight: 700;
        font-size: .88rem;
    }

    .trip-selector {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(10,37,64,.08);
        padding: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .sea-badge {
        background: #dbeafe;
        color: #1e40af;
        padding: .2rem .6rem;
        border-radius: 50px;
        font-size: .72rem;
        font-weight: 700;
    }

    .port-badge {
        background: #dcfce7;
        color: #15803d;
        padding: .2rem .6rem;
        border-radius: 50px;
        font-size: .72rem;
        font-weight: 700;
    }
</style>

<div class="admin-header">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between">
            <div>
                <h2>🗺️ Manage Itinerary</h2>
                <p style="opacity:.7;margin:0;">
                    @(selectedTrip != null ? $"Editing: {selectedTrip.Heading}" : "Select a trip to manage its itinerary")
                </p>
            </div>
            <a asp-controller="Home" asp-action="Index"
               style="background:rgba(255,255,255,.15);color:#fff;border:1px solid rgba(255,255,255,.3);padding:.5rem 1.25rem;border-radius:50px;text-decoration:none;font-weight:600;font-size:.88rem;">
                🏠 Back to Site
            </a>
        </div>
    </div>
</div>

<div class="container pb-5">
    <div class="admin-nav">
        <a asp-controller="Admin" asp-action="Index">📊 Dashboard</a>
        <a asp-controller="Admin" asp-action="Trips">🚢 Trips</a>
        <a asp-controller="Admin" asp-action="Itinerary" class="active">🗺️ Itinerary</a>
        <a asp-controller="Admin" asp-action="Bookings">🎫 Bookings</a>
        <a asp-controller="Admin" asp-action="Users">👥 Users</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-3 mb-3">✅ @TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-3 mb-3">❌ @TempData["Error"]</div>
    }

    <!-- Trip Selector -->
    <div class="trip-selector">
        <form asp-controller="Admin" asp-action="Itinerary" method="get" class="d-flex align-items-end gap-3 flex-wrap">
            <div style="flex:1;min-width:200px;">
                <label class="form-label">Select Trip</label>
                <select name="tripId" class="form-select" onchange="this.form.submit()">
                    <option value="0">-- Select a trip --</option>
                    @foreach (var t in trips)
                    {
                        <option value="@t.Id" selected="@(t.Id == selectedTripId)">
                            #@t.Id — @t.Heading (@t.Nights nights)
                        </option>
                    }
                </select>
            </div>
        </form>
    </div>

    @if (selectedTripId > 0)
    {
        <!-- Add New Item Form -->
        <div class="admin-card">
            <div class="admin-card-header">
                <h5>➕ Add Itinerary Item</h5>
            </div>
            <div style="padding:1.5rem;">
                <form asp-controller="Admin" asp-action="AddItineraryItem" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="TripId" value="@selectedTripId" />

                    <div class="row g-3">
                        <div class="col-md-2">
                            <label class="form-label">Day Number</label>
                            <input name="DayNumber" type="number" min="1" class="form-control" placeholder="1" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Location</label>
                            <input name="Location" class="form-control" placeholder="e.g. Mumbai Port" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Date</label>
                            <input name="Date" type="date" class="form-control" required />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">At Sea?</label>
                            <div class="form-check mt-2">
                                <input name="IsAtSea" type="checkbox" class="form-check-input" id="isAtSea" value="true" />
                                <label class="form-check-label" for="isAtSea">Yes</label>
                            </div>
                        </div>
                        <div class="col-md-1 d-flex align-items-end">
                            <button type="submit" class="btn btn-add w-100">Add</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Itinerary Items Table -->
        <div class="admin-card">
            <div class="admin-card-header">
                <h5>🗺️ Itinerary Items — @(selectedTrip?.Heading ?? $"Trip #{selectedTripId}")</h5>
                <span style="font-size:.85rem;color:var(--muted);">@Model.Count day(s)</span>
            </div>
            @if (Model.Count == 0)
            {
                <div class="text-center py-5 text-muted">
                    <div style="font-size:3rem;opacity:.4;">🗺️</div>
                    <p class="mt-2">No itinerary items yet. Add the first one above.</p>
                </div>
            }
            else
            {
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Day</th>
                            <th>Location</th>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderBy(i => i.DayNumber))
                        {
                            <tr>
                                <td><strong>Day @item.DayNumber</strong></td>
                                <td>@item.Location</td>
                                <td>@item.Date.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (item.IsAtSea)
                                    {
                                        <span class="sea-badge">🌊 At Sea</span>
                                    }
                                    else
                                    {
                                        <span class="port-badge">⚓ Port</span>
                                    }
                                </td>
                                <td>
                                    <form asp-controller="Admin" asp-action="DeleteItineraryItem" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="tripId" value="@selectedTripId" />
                                        <button type="submit" class="btn-del-sm"
                                                onclick="return confirm('Delete Day @item.DayNumber — @item.Location?')">
                                            🗑️
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
</div>
