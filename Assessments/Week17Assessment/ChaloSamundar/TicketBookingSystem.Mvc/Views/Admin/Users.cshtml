@model List<TicketBookingSystem.Mvc.ViewModels.AdminUserViewModel>

@{
    ViewData["Title"] = "Manage Users";
}

<style>
    :root {
        --brand: #32B096;
        --brand-dark: #279078;
        --ink: #0f172a;
        --muted: #64748b;
        --border: #e2e8f0;
    }

    .admin-header {
        background: linear-gradient(135deg,#1e293b,#0f172a);
        color: #fff;
        padding: 2rem 0;
        margin-bottom: 2rem;
    }

        .admin-header h2 {
            font-weight: 800;
            font-size: 1.8rem;
        }

    .admin-nav {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(10,37,64,.06);
        padding: 1rem 1.5rem;
        margin-bottom: 2rem;
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
    }

        .admin-nav a {
            padding: .5rem 1.2rem;
            border-radius: 50px;
            font-weight: 600;
            font-size: .88rem;
            text-decoration: none;
            color: var(--muted);
            transition: all .2s;
        }

            .admin-nav a:hover, .admin-nav a.active {
                background: var(--brand);
                color: #fff;
            }

    .admin-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(10,37,64,.08);
        overflow: hidden;
    }

    .admin-card-header {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .admin-card-header h5 {
            font-weight: 700;
            margin: 0;
        }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
    }

        .admin-table th {
            font-size: .72rem;
            font-weight: 700;
            letter-spacing: .7px;
            text-transform: uppercase;
            color: var(--muted);
            padding: .9rem 1.25rem;
            border-bottom: 1px solid var(--border);
            background: #fafbfc;
        }

        .admin-table td {
            padding: .9rem 1.25rem;
            border-bottom: 1px solid var(--border);
            font-size: .88rem;
            color: var(--ink);
            vertical-align: middle;
        }

        .admin-table tr:last-child td {
            border-bottom: none;
        }

        .admin-table tr:hover td {
            background: #f8fafc;
        }

    .user-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg,#32B096,#279078);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: .9rem;
        flex-shrink: 0;
    }

    .role-admin {
        background: #fef9c3;
        color: #92400e;
        padding: .2rem .7rem;
        border-radius: 50px;
        font-size: .72rem;
        font-weight: 700;
    }

    .role-user {
        background: #dbeafe;
        color: #1e40af;
        padding: .2rem .7rem;
        border-radius: 50px;
        font-size: .72rem;
        font-weight: 700;
    }

    .btn-del-sm {
        background: #fff0f0;
        color: #ef4444;
        border: 1.5px solid #ef4444;
        padding: .3rem .8rem;
        border-radius: 8px;
        font-size: .78rem;
        font-weight: 600;
        cursor: pointer;
    }

    .search-box {
        border: 1.5px solid var(--border);
        border-radius: 50px;
        padding: .45rem 1rem;
        font-size: .88rem;
        width: 240px;
        outline: none;
    }

        .search-box:focus {
            border-color: var(--brand);
        }
</style>

<div class="admin-header">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between">
            <div>
                <h2>👥 Manage Users</h2>
                <p style="opacity:.7;margin:0;">@Model.Count registered user(s)</p>
            </div>
            <a asp-controller="Home" asp-action="Index"
               style="background:rgba(255,255,255,.15);color:#fff;border:1px solid rgba(255,255,255,.3);padding:.5rem 1.25rem;border-radius:50px;text-decoration:none;font-weight:600;font-size:.88rem;">
                🏠 Back to Site
            </a>
        </div>
    </div>
</div>

<div class="container pb-5">
    <div class="admin-nav">
        <a asp-controller="Admin" asp-action="Index">📊 Dashboard</a>
        <a asp-controller="Admin" asp-action="Trips">🚢 Trips</a>
        <a asp-controller="Admin" asp-action="Bookings">🎫 Bookings</a>
        <a asp-controller="Admin" asp-action="Users" class="active">👥 Users</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-3 mb-4">✅ @TempData["Success"]</div>
    }

    <div class="admin-card">
        <div class="admin-card-header">
            <h5>👥 All Users</h5>
            <input type="text" id="searchBox" class="search-box" placeholder="🔍 Search by email or name..." onkeyup="filterTable()">
        </div>
        <div class="table-responsive">
            <table class="admin-table" id="usersTable">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Email</th>
                        <th>Full Name</th>
                        <th>Phone</th>
                        <th>Role</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        var initial = string.IsNullOrWhiteSpace(u.FullName)
                        ? u.Email[0].ToString().ToUpper()
                        : u.FullName[0].ToString().ToUpper();
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="user-avatar">@initial</div>
                                    <span style="font-family:monospace;font-size:.75rem;color:var(--muted);">@u.Id[..8]...</span>
                                </div>
                            </td>
                            <td>@u.Email</td>
                            <td>@(u.FullName ?? "—")</td>
                            <td>@(u.PhoneNumber ?? "—")</td>
                            <td>
                                <span class="role-@u.Role.ToLower()">@u.Role</span>
                            </td>
                            <td>
                                @if (u.Role != "Admin")
                                {
                                    <form asp-controller="Admin" asp-action="DeleteUser" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@u.Id" />
                                        <button type="submit" class="btn-del-sm"
                                                onclick="return confirm('Delete user @u.Email?')">
                                            🗑️ Delete
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span style="font-size:.78rem;color:var(--muted);">Protected</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function filterTable() {
            const q = document.getElementById('searchBox').value.toLowerCase();
            document.querySelectorAll('#usersTable tbody tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
            });
        }
    </script>
}
