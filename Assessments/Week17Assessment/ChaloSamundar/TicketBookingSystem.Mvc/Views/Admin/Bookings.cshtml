@model List<TicketBookingSystem.Mvc.DTOs.BookingDto>

@{
    ViewData["Title"] = "All Bookings";
}

<style>
    :root { --brand:#32B096; --brand-dark:#279078; --ink:#0f172a; --muted:#64748b; --border:#e2e8f0; }
    .admin-header { background:linear-gradient(135deg,#1e293b,#0f172a); color:#fff; padding:2rem 0; margin-bottom:2rem; }
    .admin-header h2 { font-weight:800; font-size:1.8rem; }
    .admin-nav { background:#fff; border-radius:16px; box-shadow:0 4px 20px rgba(10,37,64,.06); padding:1rem 1.5rem; margin-bottom:2rem; display:flex; gap:.5rem; flex-wrap:wrap; }
    .admin-nav a { padding:.5rem 1.2rem; border-radius:50px; font-weight:600; font-size:.88rem; text-decoration:none; color:var(--muted); transition:all .2s; }
    .admin-nav a:hover, .admin-nav a.active { background:var(--brand); color:#fff; }
    .admin-card { background:#fff; border-radius:16px; box-shadow:0 4px 20px rgba(10,37,64,.08); overflow:hidden; }
    .admin-card-header { padding:1.25rem 1.5rem; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; }
    .admin-card-header h5 { font-weight:700; margin:0; }
    .admin-table { width:100%; border-collapse:collapse; }
    .admin-table th { font-size:.72rem; font-weight:700; letter-spacing:.7px; text-transform:uppercase; color:var(--muted); padding:.9rem 1.25rem; border-bottom:1px solid var(--border); background:#fafbfc; }
    .admin-table td { padding:.9rem 1.25rem; border-bottom:1px solid var(--border); font-size:.88rem; color:var(--ink); vertical-align:middle; }
    .admin-table tr:last-child td { border-bottom:none; }
    .admin-table tr:hover td { background:#f8fafc; }
    .btn-del-sm { background:#fff0f0; color:#ef4444; border:1.5px solid #ef4444; padding:.3rem .8rem; border-radius:8px; font-size:.78rem; font-weight:600; cursor:pointer; }
    .badge-confirmed { background:#dcfce7; color:#15803d; padding:.2rem .7rem; border-radius:50px; font-size:.72rem; font-weight:700; }
    .badge-initiated  { background:#fef9c3; color:#92400e; padding:.2rem .7rem; border-radius:50px; font-size:.72rem; font-weight:700; }
    .badge-cancelled  { background:#fee2e2; color:#b91c1c; padding:.2rem .7rem; border-radius:50px; font-size:.72rem; font-weight:700; }

    /* Search box */
    .search-box { border:1.5px solid var(--border); border-radius:50px; padding:.45rem 1rem; font-size:.88rem; width:260px; outline:none; }
    .search-box:focus { border-color:var(--brand); }
</style>

<div class="admin-header">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between">
            <div>
                <h2>🎫 All Bookings</h2>
                <p style="opacity:.7;margin:0;">@Model.Count total booking(s)</p>
            </div>
            <a asp-controller="Home" asp-action="Index"
               style="background:rgba(255,255,255,.15);color:#fff;border:1px solid rgba(255,255,255,.3);padding:.5rem 1.25rem;border-radius:50px;text-decoration:none;font-weight:600;font-size:.88rem;">
                🏠 Back to Site
            </a>
        </div>
    </div>
</div>

<div class="container pb-5">
    <div class="admin-nav">
        <a asp-controller="Admin" asp-action="Index">📊 Dashboard</a>
        <a asp-controller="Admin" asp-action="Trips">🚢 Trips</a>
        <a asp-controller="Admin" asp-action="Bookings" class="active">🎫 Bookings</a>
        <a asp-controller="Admin" asp-action="Users">👥 Users</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-3 mb-4">✅ @TempData["Success"]</div>
    }

    <div class="admin-card">
        <div class="admin-card-header">
            <h5>🎫 All Bookings</h5>
            <input type="text" id="searchBox" class="search-box" placeholder="🔍 Search by user or journey..." onkeyup="filterTable()">
        </div>
        <div class="table-responsive">
            <table class="admin-table" id="bookingsTable">
                <thead>
                    <tr>
                        <th>Reference</th>
                        <th>User</th>
                        <th>Journey</th>
                        <th>Cabin</th>
                        <th>Passengers</th>
                        <th>Booked On</th>
                        <th>Fare</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model)
                    {
                        var pax = b.Passengers?.Count > 0 ? b.Passengers.Count : b.NumberOfPassengers;
                        var statusClass = b.Status switch
                        {
                            0 => "confirmed",
                            1 => "cancelled",
                            _ => "initiated"
                        };
                        var statusText = b.Status switch
                        {
                            0 => "Confirmed",
                            1 => "Cancelled",
                            _ => "Initiated"
                        };
                        <tr>
                            <td><span style="font-family:monospace;font-size:.78rem;">@b.BookingReference[..8]...</span></td>
                            <td style="max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@b.UserId">@(b.UserId ?? "—")</td>
                            <td>@(b.JourneyName ?? "—")</td>
                            <td>@(b.CabinType ?? "—")</td>
                            <td>@pax</td>
                            <td>@(b.BookingDate == default ? "—" : b.BookingDate.ToString("dd MMM yyyy"))</td>
                            <td>₹@b.TotalFare.ToString("N0")</td>
                            <td><span class="badge-@statusClass">@statusText</span></td>
                            <td>
                                <form asp-controller="Admin" asp-action="DeleteBooking" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="reference" value="@b.BookingReference" />
                                    <button type="submit" class="btn-del-sm"
                                            onclick="return confirm('Delete this booking?')">🗑️</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
function filterTable() {
    const q = document.getElementById('searchBox').value.toLowerCase();
    document.querySelectorAll('#bookingsTable tbody tr').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
}
</script>
}
