@model IReadOnlyList<TicketBookingSystem.Mvc.ViewModels.TripViewModel>

@{
    ViewData["Title"] = "Manage Trips";
}

<style>
    :root {
        --brand: #32B096;
        --brand-dark: #279078;
        --ink: #0f172a;
        --muted: #64748b;
        --surface: #f8fafc;
        --border: #e2e8f0;
    }

    .admin-header {
        background: linear-gradient(135deg,#1e293b,#0f172a);
        color: #fff;
        padding: 2rem 0;
        margin-bottom: 2rem;
    }

        .admin-header h2 {
            font-weight: 800;
            font-size: 1.8rem;
        }

    .admin-nav {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(10,37,64,.06);
        padding: 1rem 1.5rem;
        margin-bottom: 2rem;
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
    }

        .admin-nav a {
            padding: .5rem 1.2rem;
            border-radius: 50px;
            font-weight: 600;
            font-size: .88rem;
            text-decoration: none;
            color: var(--muted);
            transition: all .2s;
        }

            .admin-nav a:hover, .admin-nav a.active {
                background: var(--brand);
                color: #fff;
            }

    .admin-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(10,37,64,.08);
        overflow: hidden;
    }

    .admin-card-header {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .admin-card-header h5 {
            font-weight: 700;
            margin: 0;
        }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
    }

        .admin-table th {
            font-size: .72rem;
            font-weight: 700;
            letter-spacing: .7px;
            text-transform: uppercase;
            color: var(--muted);
            padding: .9rem 1.25rem;
            border-bottom: 1px solid var(--border);
            background: #fafbfc;
        }

        .admin-table td {
            padding: .9rem 1.25rem;
            border-bottom: 1px solid var(--border);
            font-size: .88rem;
            color: var(--ink);
            vertical-align: middle;
        }

        .admin-table tr:last-child td {
            border-bottom: none;
        }

        .admin-table tr:hover td {
            background: #f8fafc;
        }

    .btn-add {
        background: linear-gradient(135deg,var(--brand),var(--brand-dark));
        color: #fff;
        border: none;
        padding: .55rem 1.25rem;
        border-radius: 50px;
        font-weight: 700;
        font-size: .85rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

    .btn-edit-sm {
        background: #f0fdf9;
        color: var(--brand);
        border: 1.5px solid var(--brand);
        padding: .3rem .8rem;
        border-radius: 8px;
        font-size: .78rem;
        font-weight: 600;
        text-decoration: none;
    }

    .btn-del-sm {
        background: #fff0f0;
        color: #ef4444;
        border: 1.5px solid #ef4444;
        padding: .3rem .8rem;
        border-radius: 8px;
        font-size: .78rem;
        font-weight: 600;
        cursor: pointer;
    }
</style>

<div class="admin-header">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between">
            <div>
                <h2>🚢 Manage Trips</h2>
                <p style="opacity:.7;margin:0;">@Model.Count trip(s) in the system</p>
            </div>
            <a asp-controller="Home" asp-action="Index"
               style="background:rgba(255,255,255,.15);color:#fff;border:1px solid rgba(255,255,255,.3);padding:.5rem 1.25rem;border-radius:50px;text-decoration:none;font-weight:600;font-size:.88rem;">
                🏠 Back to Site
            </a>
        </div>
    </div>
</div>

<div class="container pb-5">
    <div class="admin-nav">
        <a asp-controller="Admin" asp-action="Index">📊 Dashboard</a>
        <a asp-controller="Admin" asp-action="Trips" class="active">🚢 Trips</a>
        <a asp-controller="Admin" asp-action="Bookings">🎫 Bookings</a>
        <a asp-controller="Admin" asp-action="Users">👥 Users</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-3 mb-4">✅ @TempData["Success"]</div>
    }

    <div class="admin-card">
        <div class="admin-card-header">
            <h5>🚢 All Trips</h5>
            <a asp-controller="Admin" asp-action="CreateTrip" class="btn-add">+ Add Trip</a>
        </div>
        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Heading</th>
                        <th>Ship</th>
                        <th>Type</th>
                        <th>Nights</th>
                        <th>Start</th>
                        <th>Price</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model)
                    {
                        <tr>
                            <td><span style="font-family:monospace;">#@t.Id</span></td>
                            <td><strong>@t.Heading</strong></td>
                            <td>@(t.ShipName ?? "—")</td>
                            <td>@(t.TripType ?? "—")</td>
                            <td>@t.Nights nights</td>
                            <td>@t.StartDate.ToString("dd MMM yyyy")</td>
                            <td>₹@t.Price.ToString("N0")</td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-controller="Admin" asp-action="EditTrip"
                                       asp-route-id="@t.Id" class="btn-edit-sm">✏️ Edit</a>
                                    <form asp-controller="Admin" asp-action="DeleteTrip"
                                          asp-route-id="@t.Id" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-del-sm"
                                                onclick="return confirm('Delete this trip?')">
                                            🗑️
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
