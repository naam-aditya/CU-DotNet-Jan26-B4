@model TicketBookingSystem.Mvc.ViewModels.CabinSelectionViewModel
@{
    ViewData["Title"] = "Cabins";
    var fallbackImages = new[]
    {
        "https://commons.wikimedia.org/wiki/Special:Redirect/file/Inside_a_stateroom_on_the_Royal_Clipper_-_33346459638.jpg",
        "https://commons.wikimedia.org/wiki/Special:Redirect/file/MSC_Cruise_cabin_%28%D0%9A%D0%B0%D1%8E%D1%82%D0%B0%29.jpg",
        "https://commons.wikimedia.org/wiki/Special:Redirect/file/P%26O_cabin_interior%2C_1946-1962_%2821959727418%29.jpg",
        "https://commons.wikimedia.org/wiki/Special:Redirect/file/P%26O_cabin_interior%2C_1946-1962_%2821959436510%29.jpg",
        "https://commons.wikimedia.org/wiki/Special:Redirect/file/Interior_of_a_P%26O_cruiser_cabin%2C_c_1950_%2821524657584%29.jpg"
    };
}

<style>
    :root {
        --brand: #32B096;
        --brand-dark: #279078;
        --ink: #0f172a;
        --muted: #64748b;
    }

    body { background: #f7f8fa; }

    .cabin-page { max-width: 1080px; }

    .cabin-header { text-align: center; margin-bottom: 2.5rem; }
    .cabin-header .eyebrow {
        color: var(--brand); font-weight: 700;
        font-size: .85rem; letter-spacing: 1px;
        text-transform: uppercase; margin-bottom: .5rem;
    }
    .cabin-header h1 {
        font-size: 2.25rem; font-weight: 800;
        letter-spacing: -.5px; color: var(--ink);
        margin-bottom: .5rem;
    }
    .cabin-header .meta { color: var(--muted); font-size: .9rem; margin: 0; }

    .cabin-list { display: flex; flex-direction: column; gap: 1.25rem; }

    .cabin-card {
        display: grid;
        grid-template-columns: 320px 1fr 240px;
        background: #fff;
        border: 1px solid #eceef2;
        border-radius: 16px;
        box-shadow: 0 4px 14px rgba(10,37,64,.06);
        overflow: hidden;
        transition: box-shadow .25s ease, transform .25s ease;
    }
    .cabin-card:hover {
        box-shadow: 0 20px 40px rgba(10,37,64,.1);
        transform: translateY(-3px);
    }

    .cabin-image-wrap {
        position: relative;
        min-height: 280px;
        background: #f1f5f4;
        display: flex; align-items: center; justify-content: center;
    }
    .cabin-image {
        width: 100%; height: 100%;
        object-fit: cover; display: block;
    }

    .cabin-main {
        padding: 1.6rem 1.5rem;
        display: flex; flex-direction: column; gap: 1rem;
    }
    .cabin-name {
        font-size: 1.2rem; font-weight: 800;
        margin: 0; color: var(--ink); letter-spacing: -.2px;
    }
    .cabin-description {
        color: var(--muted); margin: .35rem 0 0;
        line-height: 1.6; font-size: .92rem;
    }

    .capacity-row {
        display: flex; align-items: center; gap: .6rem;
        color: var(--ink); font-weight: 600; font-size: .92rem;
    }
    .capacity-icon {
        display: inline-flex; align-items: center; justify-content: center;
        width: 32px; height: 32px; border-radius: 10px;
        background: linear-gradient(135deg, #e6f7f0, #d4f4ea);
        color: var(--brand); font-size: 1rem;
    }

    .amenities-link {
        color: var(--brand); font-weight: 600;
        background: transparent; border: 0; padding: 0;
        text-decoration: none; font-size: .95rem;
    }
    .amenities-link:hover { color: var(--brand-dark); text-decoration: underline; }

    .amenities-list {
        margin: .75rem 0 0; padding-left: 1.1rem;
        color: var(--muted); font-size: .9rem;
    }

    .cabin-side {
        padding: 1.6rem 1.4rem;
        border-left: 1px solid #f1f5f9;
        display: flex; flex-direction: column;
        justify-content: space-between; align-items: flex-end;
        text-align: right;
    }
    .price-value {
        font-size: 1.8rem; font-weight: 800;
        color: var(--ink); line-height: 1; letter-spacing: -.5px;
    }
    .price-subtext { color: var(--ink); font-size: .9rem; margin-top: .55rem; }
    .price-note { color: var(--muted); font-size: .82rem; margin-top: .35rem; }

    .choose-btn {
        min-width: 170px; padding: .75rem 1.4rem;
        border-radius: 12px; border: none;
        background: linear-gradient(135deg, var(--brand), var(--brand-dark));
        color: #fff; font-weight: 700; letter-spacing: .3px;
        transition: all .2s ease;
    }
    .choose-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 22px rgba(50,176,150,.35);
        color: #fff;
    }

    @@media (max-width: 991.98px) {
        .cabin-card { grid-template-columns: 1fr; }
        .cabin-image-wrap { min-height: 240px; }
        .cabin-side {
            border-left: 0; border-top: 1px solid #f1f5f9;
            align-items: flex-start; text-align: left;
        }
    }
</style>

<div class="container py-5 cabin-page">
    <div class="cabin-header">
        <div class="eyebrow">Choose your stay</div>
        <h1>Pick the cabin that fits you best</h1>
        <p class="meta">Cruise @Model.CruiseId · Ship @Model.ShipId</p>
    </div>

    @if (TempData["SelectedCabinMessage"] is string selectedCabinMessage)
    {
        <div class="alert alert-success">
            @selectedCabinMessage
        </div>
    }

    @if (!Model.CabinTypes.Any())
    {
        <div class="alert alert-info">
            No cabin types are available right now.
        </div>
    }
    else
    {
        <div class="cabin-list">
            @for (var index = 0; index < Model.CabinTypes.Count; index++)
            {
                var type = Model.CabinTypes[index];
                var imageUrl = type.Images.OrderBy(i => i.DisplayOrder).FirstOrDefault()?.ImageUrl
                    ?? fallbackImages[index % fallbackImages.Length];
                <div class="cabin-card">
                    <div class="cabin-image-wrap">
                        <img src="@imageUrl" class="cabin-image" alt="@type.Name" />
                    </div>

                    <div class="cabin-main">
                        <div>
                            <h2 class="cabin-name">@type.Name</h2>
                            <p class="cabin-description">@type.Description</p>
                        </div>

                        <div class="capacity-row">
                            <span class="capacity-icon">&#128101;</span>
                            <span>Max Capacity: @type.MaxOccupancy.ToString("00") Guests</span>
                        </div>

                        <div>
                            <button type="button" class="read-more amenities-link" data-bs-toggle="collapse"
                                    data-bs-target="#amenities-@type.Id" aria-expanded="false" aria-controls="amenities-@type.Id">
                                View Amenities
                            </button>

                            <div class="collapse" id="amenities-@type.Id">
                                @if (type.Amenities.Any())
                                {
                                    <ul class="amenities-list">
                                        @foreach (var amenity in type.Amenities)
                                        {
                                            <li>@amenity.Name</li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <p class="text-muted mb-0 mt-2">No amenities listed.</p>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="cabin-side">
                        <div>
                            <div class="price-value">Rs @string.Format("{0:N0}", type.PricePerPerson)</div>
                            <div class="price-subtext">Per Person in Double Occupancy</div>
                            <div class="price-note">Excl. GST charges</div>
                        </div>

                        <form asp-action="Select" asp-controller="Cabin" method="post">
                            <input type="hidden" name="cabinTypeId" value="@type.Id" />
                            <input type="hidden" name="cruiseId" value="@Model.CruiseId" />
                            <input type="hidden" name="shipId" value="@Model.ShipId" />
                            <button type="submit" class="choose-btn">Choose Cabin</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>
