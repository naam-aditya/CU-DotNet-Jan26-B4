@model TicketBookingSystem.Mvc.DTOs.LoginDto;
@{
    ViewData["Title"] = "Sign In";
    ViewData["HideFooter"] = true;
}

<style>
    /* --- AGGRESSIVE OVERRIDES TO KILL SCROLLBAR & FOOTER --- */
    html, body {
        overflow: hidden !important;
        height: 100vh !important;
        margin: 0 !important;
        padding: 0 !important;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    }

    footer, .footer {
        display: none !important;
    }

    main {
        padding: 0 !important;
        margin: 0 !important;
        max-width: 100% !important;
    }
    /* ----------------------------------------------------- */

    /* Custom Background */
    .auth-bg-wrapper {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url('https://images.unsplash.com/photo-1548574505-5e239809ee19?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80');
        background-size: cover;
        background-position: center;
        filter: blur(15px) brightness(0.7);
        transform: scale(1.1);
        z-index: -1;
    }

    /* Custom Theme Colors & Specific Radii not in standard Bootstrap */
    .text-theme { color: #32B096 !important; }
    
    .bg-theme {
        background-color: #32B096;
        color: white;
        transition: background-color 0.2s ease-in-out;
    }
    .bg-theme:hover {
        background-color: #27917a;
        color: white;
    }

    .card-custom {
        background: rgba(255, 255, 255, 0.98);
        border-radius: 12px;
    }
    
    .input-custom {
        border-radius: 6px;
    }
</style>

<div class="auth-bg-wrapper"></div>

<div class="vh-100 d-flex align-items-center justify-content-center px-3">
    <div class="container">
        
        <div class="row g-0 card-custom border-0 shadow-lg mx-auto overflow-hidden" style="max-width: 850px;">
            
            <div class="col-lg-6 d-none d-lg-block position-relative"
                 style="background: url('https://images.unsplash.com/photo-1548574505-5e239809ee19?ixlib=rb-4.0.3&auto=format&fit=crop&w=850&q=80') center/cover;">
                
                <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(transparent, rgba(0,0,0,0.7));"></div>
                
                <div class="d-flex flex-column justify-content-end h-100 p-4 text-white position-relative z-1">
                    <h2 class="fw-bold fs-3">Welcome to<br />Cruise Booking</h2>
                    <p class="text-white-50 mb-0 small">Find your perfect getaway on the sea.</p>
                </div>
            </div>

            <div class="col-lg-6 p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="fw-bold m-0 fs-4">Log in</h3>
                    <a asp-action="Register" class="text-theme fw-bold text-decoration-none small">Sign up</a>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger py-2 small">@ViewBag.Error</div>
                }

                <form asp-controller="Auth" asp-action="Login" method="post" novalidate>
                    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label small fw-bold text-muted mb-1">Email address</label>
                        <input asp-for="Email" class="form-control bg-light px-3 py-2 input-custom" placeholder="name@example.com" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label small fw-bold text-muted mb-1">Password</label>
                        <input asp-for="Password" type="password" class="form-control bg-light px-3 py-2 input-custom" placeholder="••••••••" />
                    </div>

                    <button type="submit" class="btn bg-theme w-100 mb-3 py-2 fw-semibold input-custom">Log in</button>
                    
                    <div class="text-center">
                        <a href="#" class="small text-muted text-decoration-none">Forgot password?</a>
                    </div>
                </form>
            </div>
        </div>
        
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}