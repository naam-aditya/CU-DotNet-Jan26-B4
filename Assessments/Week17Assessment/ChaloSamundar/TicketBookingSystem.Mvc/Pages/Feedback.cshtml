@page "/Feedback"
@model TicketBookingSystem.Mvc.Pages.FeedbackModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Customer Feedback";
}

<style>
    /* Professional Theme Styles */
    body {
        background-color: #f8fafc; /* Very light, professional slate/gray */
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        color: #334155;
    }

    .feedback-container {
        padding: 4rem 15px;
        max-width: 800px;
        margin: 0 auto;
    }

    .professional-card {
        background: #ffffff;
        border-radius: 8px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        border: 1px solid #e2e8f0;
        padding: 2.5rem;
    }

    .card-header-custom {
        border-bottom: 1px solid #e2e8f0;
        padding-bottom: 1.5rem;
        margin-bottom: 2rem;
    }

        .card-header-custom h2 {
            color: #0f172a;
            font-weight: 600;
            margin: 0;
            font-size: 1.75rem;
        }

        .card-header-custom p {
            color: #64748b;
            margin-top: 0.5rem;
            margin-bottom: 0;
            font-size: 0.95rem;
        }

    .form-label {
        font-weight: 500;
        color: #475569;
        margin-bottom: 0.4rem;
        font-size: 0.9rem;
    }

    .form-control, .form-select {
        border-radius: 6px;
        border: 1px solid #cbd5e1;
        padding: 0.6rem 0.8rem;
        font-size: 0.95rem;
        background-color: #fff;
        transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
    }

        .form-control:focus, .form-select:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
            outline: none;
        }

    .btn-primary-custom {
        background-color: #2563eb; /* Professional corporate blue */
        color: white;
        border: none;
        border-radius: 6px;
        padding: 0.6rem 1.5rem;
        font-weight: 500;
        transition: background-color 0.2s;
    }

        .btn-primary-custom:hover {
            background-color: #1d4ed8;
            color: white;
        }

    .btn-secondary-custom {
        background-color: #f1f5f9;
        color: #475569;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        padding: 0.6rem 1.5rem;
        font-weight: 500;
        transition: all 0.2s;
        text-decoration: none;
    }

        .btn-secondary-custom:hover {
            background-color: #e2e8f0;
            color: #0f172a;
        }
</style>

<div class="feedback-container">
    <div class="professional-card">
        <div class="card-header-custom">
            <h2>Customer Feedback</h2>
            <p>We value your experience. Please share your thoughts below.</p>
        </div>

        @if (Model.SuccessMessage != null)
        {
            <div class="alert alert-success d-flex align-items-center mb-4" role="alert">
                <div>@Model.SuccessMessage</div>
            </div>
        }

        <form method="post" asp-page="Feedback">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="row g-4 mb-3">
                <div class="col-md-6">
                    <label asp-for="Feedback.Name" class="form-label">Full Name</label>
                    <input asp-for="Feedback.Name" class="form-control" placeholder="John Doe" />
                    <span asp-validation-for="Feedback.Name" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Feedback.Email" class="form-label">Email Address</label>
                    <input asp-for="Feedback.Email" class="form-control" placeholder="name@company.com" />
                    <span asp-validation-for="Feedback.Email" class="text-danger small mt-1 d-block"></span>
                </div>
            </div>

            <div class="row g-4 mb-3">
                <div class="col-md-6">
                    <label asp-for="Feedback.BookingId" class="form-label">Booking Reference</label>
                    <input asp-for="Feedback.BookingId" class="form-control" placeholder="e.g. BK-12345" />
                    <span asp-validation-for="Feedback.BookingId" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Feedback.TripId" class="form-label">Trip Identifier</label>
                    <input asp-for="Feedback.TripId" class="form-control" placeholder="e.g. TR-9876" />
                    <span asp-validation-for="Feedback.TripId" class="text-danger small mt-1 d-block"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Feedback.Rating" class="form-label">Overall Rating (1-5)</label>
                <select asp-for="Feedback.Rating" class="form-select" style="max-width: 200px;">
                    <option value="">Select a rating...</option>
                    <option value="5">5 - Excellent</option>
                    <option value="4">4 - Good</option>
                    <option value="3">3 - Average</option>
                    <option value="2">2 - Poor</option>
                    <option value="1">1 - Terrible</option>
                </select>
                <span asp-validation-for="Feedback.Rating" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Feedback.Message" class="form-label">Detailed Feedback</label>
                <textarea asp-for="Feedback.Message" class="form-control" rows="4" placeholder="Please provide specific details about your experience..."></textarea>
                <span asp-validation-for="Feedback.Message" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="d-flex gap-3 justify-content-end border-top pt-4 mt-2">
                <a asp-page="/Index" class="btn btn-secondary-custom">Cancel</a>
                <button type="submit" class="btn btn-primary-custom px-4">Submit Feedback</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}