@using NorthwindCatalog.Services.Dtos;
@model List<CategorySummaryDto>

@{
    ViewData["Title"] = "Category Summary";
}

<div class="container mt-5">
    <h1 class="mb-4">Category Summary Analytics</h1>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Category Name</th>
                    <th>Product Count</th>
                    <th>Average Price</th>
                    <th>Most Expensive Product</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var summary in Model ?? new List<CategorySummaryDto>())
                {
                    <tr>
                        <td>@summary.CategoryName</td>
                        <td><span class="badge bg-primary">@summary.ProductCount</span></td>
                        <td>$@summary.AvgPrice.ToString("F2")</td>
                        <td>@summary.MostExpensiveProduct</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            No summary data available.
        </div>
    }
</div>
