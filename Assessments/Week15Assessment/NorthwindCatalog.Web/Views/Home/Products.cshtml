@using NorthwindCatalog.Services.Dtos;
@model List<ProductDto>

@{
    ViewData["Title"] = "Products";
}

<div class="container mt-5">
    <div class="mb-4">
        <a href="@Url.Action("Categories", "Home")" class="btn btn-secondary">← Back to Categories</a>
    </div>

    <h1 class="mb-4">Products</h1>

    <div class="row">
        @foreach (var product in Model ?? new List<ProductDto>())
        {
            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">@product.ProductName</h5>
                        <table class="table table-sm">
                            <tbody>
                                <tr>
                                    <td><strong>Unit Price:</strong></td>
                                    <td>$@product.UnitPrice.ToString("F2")</td>
                                </tr>
                                <tr>
                                    <td><strong>Units In Stock:</strong></td>
                                    <td>@product.UnitsInStock</td>
                                </tr>
                                <tr>
                                    <td><strong>Inventory Value:</strong></td>
                                    <td><span class="badge bg-info">$@product.InventoryValue.ToString("F2")</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            No products available in this category.
        </div>
    }
</div>
