@model List<Employee>
@{
    ViewData["DepartmentName"] = "Department Dashboard";
}

<div class="alert alert-info mt-3">
    <strong>Announcement:</strong> @ViewBag.Announcement
</div>

<h2>@ViewData["DepartmentName"] Dashboard</h2>


<div class="mt-3">
    @{
        bool isActive = (bool)ViewData["IsDepartmentActive"]!;
    }

    @if (isActive)
    {
        <div class="alert alert-success">
            Department Active
        </div>
    }
    else
    {
        <div class="alert alert-danger">
            Department Under Maintenance
        </div>
    }
</div>

<table class="table table-striped table-bordered table mt-4">
    <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Position</th>
            <th>Salary</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var employee in Model)
        {
            <tr>
                <td>@employee.Id</td>
                <td>@employee.Name</td>
                <td>@employee.Position</td>
                <td>@employee.Salary</td>
            </tr>
        }
    </tbody>
</table>